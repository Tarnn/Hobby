# Contact form (Resend — https://resend.com). Optional until you wire up the form.
# Without RESEND_API_KEY the form shows a friendly "email me directly" message.
RESEND_API_KEY=

# Sender address for contact emails. For quick testing you can use the default
# "Portfolio <onboarding@resend.dev>" (only delivers to your own account email).
# For production, verify your domain in Resend and use e.g. "Tarnnn <hello@tarnnn.com>".
CONTACT_FROM=

# Optional: override the S3 asset base URL (defaults to the live bucket in code).
# NEXT_PUBLIC_AWS_S3_HOBBY_CDN=
